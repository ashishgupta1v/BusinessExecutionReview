APP_NAME="Business Execution Toolkit"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dhandadiary.cloud

APP_TIMEZONE=Asia/Kolkata

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (PostgreSQL 16) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=execution_cockpit
DB_USERNAME=cockpit
DB_PASSWORD=

# --- Sessions / queue / cache (database-backed = zero extra services) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Google OAuth (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- Web Push (VAPID) — generate with: php artisan webpush:vapid ---
# VAPID_SUBJECT is mandatory or iOS rejects pushes (BadJwtToken). Never rotate the keys.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:you@example.com"

# --- Transactional email (Brevo / Postmark / Mailgun via SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="you@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Razorpay (Phase 3 billing; leave blank until then) ---
RAZORPAY_KEY=
RAZORPAY_SECRET=
